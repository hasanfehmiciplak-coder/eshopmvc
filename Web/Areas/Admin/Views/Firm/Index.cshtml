@model IEnumerable<EShopMVC.Models.Firm>

@{
    ViewData["Title"] = "Firmalar";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Üretici Firmalar</h2>
    <a asp-action="Create" class="btn btn-primary">Yeni Firma</a>
</div>

<table class="table table-bordered table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Firma Adı</th>
            <th>Durum</th>
            <th>Ürün Sayısı</th>
            <th width="220">İşlemler</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var firm in Model)
        {
            <tr>
                <td>@firm.Name</td>
                <td>
                    @if (firm.IsActive)
                    {
                        <span class="badge bg-success">Aktif</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Pasif</span>
                    }
                </td>
                <td>@(firm.Products?.Count ?? 0)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@firm.Id" class="btn btn-sm btn-warning">Düzenle</a>
                    <a asp-action="Delete" asp-route-id="@firm.Id" class="btn btn-sm btn-danger">Sil</a>
                </td>
            </tr>
        }
    </tbody>
</table>
