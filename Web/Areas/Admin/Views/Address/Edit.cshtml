@using EShopMVC.Modules.Orders.Models
@model CustomerAddress

<h4>Adres Düzenle</h4>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label class="form-label">Adres Başlığı</label>
        <input asp-for="Title" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Adres</label>
        <textarea asp-for="FullAddress" class="form-control"></textarea>
    </div>
    <div class="mb-3">
        <label class="form-label">Telefon</label>
        <input asp-for="Phone" class="form-control" />
    </div>


    <div class="row">
        <div class="col-md-6 mb-3">
            <label class="form-label">İl</label>
            <input asp-for="City" class="form-control" />
        </div>

        <div class="col-md-6 mb-3">
            <label class="form-label">İlçe</label>
            <input asp-for="District" class="form-control" />
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label">Posta Kodu</label>
        <input asp-for="PostalCode" class="form-control" />
    </div>

    <div class="form-check mb-3">
        <input asp-for="IsDefault" class="form-check-input" />
        <label class="form-check-label">Varsayılan adres yap</label>
    </div>

    <button type="submit" class="btn btn-success">Güncelle</button>
    <a asp-action="Index" class="btn btn-secondary">İptal</a>
</form>
