@model List<EShopMVC.Models.AuditLog>

<h3>👤 Audit Detayı</h3>

<div class="alert alert-info">
    Kullanıcı: <strong>@ViewBag.Email</strong>
</div>

<a asp-action="Index" class="btn btn-sm btn-secondary mb-3">
    ← Audit Listeye Dön
</a>

<table class="table table-bordered table-sm">
    <thead class="table-light">
        <tr>
            <th>Tarih</th>
            <th>Aksiyon</th>
            <th>IP</th>
            <th>Tarayıcı</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var log in Model)
        {
            var badge = log.Action switch
            {
                "LOGIN_SUCCESS" => "bg-success",
                "LOGIN_FAIL" => "bg-danger",
                "LOGIN_LOCKED" => "bg-warning text-dark",
                "RESET_PASSWORD" => "bg-info",
                _ => "bg-secondary"
            };

            <tr class="@(log.Action == "LOGIN_FAIL" ? "table-danger" : "")">
                <td>@log.CreatedAt.ToString("dd.MM.yyyy HH:mm:ss")</td>
                <td>
                    <span class="badge @badge">
                        @log.Action
                    </span>
                </td>
                <td>@log.IpAddress</td>
                <td style="max-width:300px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                    @log.UserAgent
                </td>
            </tr>
        }
    </tbody>
</table>
