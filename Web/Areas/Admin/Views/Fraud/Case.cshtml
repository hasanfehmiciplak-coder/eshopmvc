@using EShopMVC.Modules.Orders.Domain.Enums
@model OrderDetailViewModel

<h2>Fraud Case - Order #@Model.Order.Id</h2>

<hr />

<h4>Refunds</h4>

<table class="table table-sm">
    <thead>
        <tr>
            <th>Reason</th>
            <th>Status</th>
            <th>Date</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var r in Model.Refunds)
        {
            <tr>
                <td>@r.Amount</td>

                <td>
                    @r.Status

                    @if (r.Status == RefundStatus.Failed)
                    {
                        <form asp-action="RetryNow"
                              asp-route-id="@r.Id"
                              method="post"
                              class="mt-1">
                            <button class="btn btn-warning btn-sm">
                                Retry
                            </button>
                        </form>
                    }
                </td>

                <td>@r.CreatedAt</td>
            </tr>
        }
    </tbody>
</table>

<h4>Fraud Flags</h4>

<table class="table table-sm">
    <thead>
        <tr>
            <th>Rule</th>
            <th>Date</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var f in Model.FraudFlags)
        {
            <tr>
                <td class="text-danger">@f.RuleCode</td>
                <td>@f.CreatedAt</td>
            </tr>
        }
    </tbody>
</table>

<h4>Timeline</h4>

<ul class="list-group">
    @foreach (var t in Model.Timeline)
    {
        <li class="list-group-item">
            <strong>@t.EventType</strong>

            <div class="text-muted small">
                @t.Description
            </div>

            <div class="text-muted small">
                @t.CreatedAt
            </div>
        </li>
    }
</ul>

