@model EShopMVC.Modules.Fraud.Models.FraudCase

<h2>Fraud Case #@Model.Id</h2>

<div class="card p-3">

    <p><strong>Order:</strong> @Model.OrderId</p>
    <p><strong>Status:</strong> @Model.Status</p>
    <p><strong>Assigned:</strong> @Model.AssignedToUserId</p>
    <p><strong>Created:</strong> @Model.CreatedAt</p>

</div>

<h3>Timeline</h3>

<table class="table">
    <thead>
        <tr>
            <th>Event</th>
            <th>Description</th>
            <th>Date</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in (IEnumerable<dynamic>)ViewBag.Timeline)
        {
            <tr>
                <td>@item.EventType</td>
                <td>@item.Description</td>
                <td>@item.CreatedAt</td>
            </tr>
        }

    </tbody>
</table>

<h3>Notes</h3>

<form method="post" asp-action="AddNote">

    <input type="hidden" name="caseId" value="@Model.Id" />

<textarea name="note" class="form-control"></textarea>

    <br />

    <button class="btn btn-primary">Add Note</button>

</form>