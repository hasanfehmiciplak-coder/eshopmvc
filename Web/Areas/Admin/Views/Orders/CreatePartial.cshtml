@using EShopMVC.Web.ViewModels
@model CreatePartialRefundVM


<form asp-action="CreatePartial" method="post">
    <input type="hidden" asp-for="OrderId" />

    <table class="table">
        <thead>
            <tr>
                <th>Ürün</th>
                <th>Satın Alınan</th>
                <th>İade Edilen</th>
                <th>İade Adedi</th>
                <th>Neden</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Items.Count; i++)
            {
                <tr>
                    <td>@Model.Items[i].ProductName</td>
                    <td>@Model.Items[i].OrderedQuantity</td>
                    <td>@Model.Items[i].AlreadyRefundedQuantity</td>

                    <td>
                        <input asp-for="Items[i].RefundQuantity"
                               class="form-control"
                               min="0"
                               max="@(Model.Items[i].OrderedQuantity - Model.Items[i].AlreadyRefundedQuantity)" />
                    </td>

                    <td>
                        <input asp-for="Items[i].Reason" class="form-control" />
                    </td>

                    <input type="hidden" asp-for="Items[i].OrderItemId" />
                    <input type="hidden" asp-for="Items[i].UnitPrice" />
                </tr>
            }
        </tbody>
    </table>

    <button class="btn btn-warning">Kısmi İade Yap</button>
</form>
