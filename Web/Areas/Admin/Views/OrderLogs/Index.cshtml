@using EShopMVC.Modules.Orders
@using EShopMVC.Modules.Orders.Models
@model List<OrderLog>

<h2>📜 Sipariş Logları (#@ViewBag.OrderId)</h2>

<a asp-area="Admin"
   asp-controller="Orders"
   asp-action="Details"
   asp-route-id="@ViewBag.OrderId"
   class="btn btn-secondary mb-3">
    ← Siparişe Dön
</a>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Tarih</th>
            <th>İşlem</th>
            <th>Açıklama</th>
            <th>Admin</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var log in Model)
        {
            <tr>
                <td>@log.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td>
                    <span class="badge bg-info">
                        @log.Action
                    </span>
                </td>
                <td>@log.Description</td>
                <td>@log.OrderId</td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        Bu sipariş için henüz log bulunmamaktadır.
    </div>
}
