@using EShopMVC.Models
@model Product

<h2>✏️ Ürün Düzenle</h2>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="Id" />
    <input type="hidden" asp-for="ImageUrl" />

    <div class="mb-3">
        <label>Ürün Adı</label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Açıklama</label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>

    <div class="mb-3">
        <label>Fiyat</label>
        <input asp-for="Price" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Stok</label>
        <input asp-for="Stock" class="form-control" />
    </div>

    <select asp-for="CategoryId"
            asp-items="ViewBag.Categories"
            class="form-select">
        <option value="0">Kategori Seçiniz</option>
    </select>
    <span asp-validation-for="CategoryId" class="text-danger"></span>

    <select asp-for="FirmId"
            asp-items="ViewBag.Firms"
            class="form-select">
        <option value="0">Firma Seçiniz</option>
    </select>
    <span asp-validation-for="FirmId" class="text-danger"></span>

    <div class="mb-3">
        <label>Mevcut Fotoğraf</label><br />
        <img src="@(Model.ImageUrl ?? "/images/no-image.png")"
             width="120" class="rounded mb-2" />
    </div>

    <div class="mb-3">
        <label>Yeni Fotoğraf (opsiyonel)</label>
        <input type="file" name="imageFile" class="form-control" />
    </div>

    <button class="btn btn-success">Güncelle</button>
    <a asp-action="Index" class="btn btn-secondary">İptal</a>
</form>
