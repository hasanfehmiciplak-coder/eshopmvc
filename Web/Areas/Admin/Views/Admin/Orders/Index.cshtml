@model List<OrderListVM>
@using EShopMVC.Helpers
@using EShopMVC.Modules.Orders
@using EShopMVC.Modules.Orders.Domain.Entities
@using EShopMVC.Modules.Orders.Domain
@using EShopMVC.Web.Areas.Admin.ViewModels

<h2>📦 Sipariş Yönetimi</h2>

<table class="table table-bordered align-middle">
    <thead class="table-dark">
        <tr>
            <th>#</th>
            <th>Kullanıcı</th>
            <th>Tarih</th>
            <th>Tutar</th>
            <th>Durum</th>
            <th>İşlem</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.Id</td>
                <td>@order.UserEmail</td>
                <td>@order.OrderDate.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@order.TotalPrice ₺</td>
                <td>
                    <span class="badge @OrderStatusHelper.BadgeClass(order.Status)">
                        @order.Status
                    </span>

                    @if (order.CancelRequested)
                    {
                        <span class="badge bg-danger ms-2">
                            ❗ İptal Talebi
                        </span>
                    }
                </td>
                <td>
                    <a asp-area="Admin"
                       asp-controller="Orders"
                       asp-action="Details"
                       asp-route-id="@order.Id"
                       class="btn btn-sm btn-primary">
                        Detay
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
