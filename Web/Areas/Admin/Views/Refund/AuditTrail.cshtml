@using EShopMVC.Modules.Payments.Models
@using EShopMVC.Models
@model PartialRefund

<h3>🧾 İade Audit Trail</h3>

<div class="mb-3">
    <strong>Sipariş:</strong> #@Model.OrderId <br />
    <strong>Ürün:</strong> @Model.OrderItem.Product.Name <br />
    <strong>Adet:</strong> @Model.Quantity <br />
    <strong>Tutar:</strong> @Model.RefundAmount ₺ <br />
    <strong>Durum:</strong>
    <span class="badge bg-info">@Model.Status</span>
</div>

<hr />

<h5>📜 İşlem Geçmişi</h5>

<table class="table table-bordered table-sm">
    <thead>
        <tr>
            <th>Tarih</th>
            <th>İşlem</th>
            <th>Sağlayıcı</th>
            <th>Tutar</th>
            <th>Detay</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var log in Model.RefundLogs.OrderBy(x => x.CreatedAt))
        {
            <tr>
                <td>@log.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                <td>
                    @if (log.Status == RefundStatus.Success)
                    {
                        <span class="badge bg-success">Başarılı</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Başarısız</span>
                    }
                </td>
                <td>@log.Provider</td>
                <td>@log.Amount ₺</td>
                <td>
                    @if (!string.IsNullOrEmpty(log.ErrorMessage))
                    {
                        <span class="text-danger">@log.ErrorMessage</span>
                    }
                    else
                    {
                        <span class="text-muted">—</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<hr />

<a asp-action="RefundPdf"
   asp-route-refundId="@Model.Id"
   class="btn btn-outline-secondary">
    📄 PDF Fiş
</a>

<a asp-action="Pending" class="btn btn-secondary">
    ← Geri Dön
</a>
