@using EShopMVC.Web.ViewModels
@model RefundDashboardVM

<h3>📊 Refund Dashboard</h3>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h6>Toplam İade</h6>
                <h3>@Model.TotalRefundCount</h3>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h6>Toplam Tutar</h6>
                <h3>@Model.TotalRefundAmount ₺</h3>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card text-center border-success">
            <div class="card-body">
                <h6>Başarılı</h6>
                <h3 class="text-success">@Model.SuccessCount</h3>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card text-center border-danger">
            <div class="card-body">
                <h6>Başarısız</h6>
                <h3 class="text-danger">@Model.FailedCount</h3>
            </div>
        </div>
    </div>

    <div class="col-md-2">
        <div class="card text-center border-warning">
            <div class="card-body">
                <h6>Bekleyen</h6>
                <h3 class="text-warning">@Model.PendingCount</h3>
            </div>
        </div>
    </div>
</div>

<div class="col-md-3">
    <div class="card text-center border-secondary">
        <div class="card-body">
            <h6>📄 PDF Fişi Hazır</h6>
            <h3>@Model.PdfAvailableCount</h3>
        </div>
    </div>
</div>

<hr />

<h5>⏳ SLA & Retry</h5>

<ul class="list-group mb-4">
    <li class="list-group-item">
        SLA İhlali (24s): <strong>@Model.SlaViolatedCount</strong>
    </li>
    <li class="list-group-item">
        Toplam Retry Sayısı: <strong>@Model.RetryCount</strong>
    </li>
    <li class="list-group-item">
        Retry Limiti Aşılan: <strong>@Model.RetryLimitExceededCount</strong>
    </li>
</ul>

<hr />

<h5>📈 Son 7 Gün</h5>

<div class="card mt-4">
    <div class="card-header">
        Fraud Events (Last 7 Days)
    </div>

    <div class="card-body">
        <canvas id="fraudChart"></canvas>
    </div>
</div>
<div class="card mt-4">

    <div class="card-header">
        Top Suspicious Orders
    </div>

    <div class="card-body">

        <table class="table table-sm">

            <thead>
                <tr>
                    <th>Order</th>
                    <th>User</th>
                    <th>Fraud Flags</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>

                @foreach (var order in ViewBag.SuspiciousOrders)
                {
                    <tr>

                        <td>#@order.Id</td>

                        <td>@order.User?.Email</td>

                        <td class="text-danger">
                            @order.FraudFlags.Count
                        </td>

                        <td>

                            <a asp-area="Admin"
                               asp-controller="Orders"
                               asp-action="Details"
                               asp-route-id="@order.Id"
                               class="btn btn-sm btn-outline-primary">

                                Inspect

                            </a>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>


<table class="table table-sm table-bordered w-50">
    <thead>
        <tr>
            <th>Tarih</th>
            <th>İade Sayısı</th>
            <th>Tutar</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in Model.Last7Days)
        {
            <tr>
                <td>@d.Date.ToString("dd.MM")</td>
                <td>@d.Count</td>
                <td>@d.Amount ₺</td>
            </tr>
        }
    </tbody>
</table>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

    const fraudLabels = @Html.Raw(Json.Serialize(ViewBag.FraudDates));
    const fraudData = @Html.Raw(Json.Serialize(ViewBag.FraudCounts));

    const ctx = document.getElementById('fraudChart');

    new Chart(ctx, {
        type: 'line',
        data: {
            labels: fraudLabels,
            datasets: [{
                label: 'Fraud Events',
                data: fraudData,
                borderWidth: 2,
                fill: false
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    display: true
                }
            }
        }
    });

</script>