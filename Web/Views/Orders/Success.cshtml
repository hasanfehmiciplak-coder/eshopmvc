@using EShopMVC.Modules.Orders.Models
@model Order

<div class="container mt-5">

    <div class="card text-center">

        <div class="card-body">

            <h2 class="text-success">
                
                <div class="success-icon">✔  Ödeme Başarılı</div>
            </h2>

            <p class="mt-3">
                Siparişiniz başarıyla oluşturuldu.
            </p>

            <h5>
                Sipariş No: #@Model.Id
            </h5>

            <h6 class="text-muted">
                Toplam Tutar: @Model.TotalPrice ₺
            </h6>

            <div class="mt-4">

                <a asp-controller="Orders"
                   asp-action="Details"
                   asp-route-id="@Model.Id"
                   class="btn btn-primary">

                    Sipariş Detayı

                </a>

                <a asp-controller="Orders"
                   asp-action="MyOrders"
                   class="btn btn-outline-secondary">

                    Siparişlerim

                </a>

                <a asp-controller="Home"
                   asp-action="Index"
                   class="btn btn-outline-dark">

                    Ana Sayfa

                </a>

            </div>

        </div>

    </div>

</div>