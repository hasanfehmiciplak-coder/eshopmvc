@using EShopMVC.Areas.Admin.ViewModels.Orders
@using EShopMVC.Models.TimeLine
@using EShopMVC.Modules.Orders
@using EShopMVC.Modules.Orders.Models

@model OrderDetailViewModel
@{
    ViewData["Title"] = "Sipariş Detayı";
    Layout = "_Layout";
}

@if (ViewBag.RiskScore >= 80)
{
    <div class="alert alert-danger mt-3">
        ⚠ Sipariş güvenlik kontrolünden geçiyor.
    </div>
}
else if (ViewBag.RiskScore >= 40)
{
    <div class="alert alert-warning mt-3">
        Sipariş ek güvenlik kontrolünde.
    </div>
}

<h2>Sipariş Detayı</h2>

<!-- ORDER PROGRESS -->
<div class="mb-4">

    <ul class="order-progress">

        <li class="@(Model.Order.Status >= OrderStatus.Pending ? "done" : "")">
            <span>🧾 Sipariş Alındı</span>
        </li>

        <li class="@(Model.Order.Status >= OrderStatus.Paid ? "done" : "")">
            <span>💳 Ödeme Alındı</span>
        </li>

        <li class="@(Model.Order.Status >= OrderStatus.Shipped ? "done" : "")">
            <span>🚚 Kargoya Verildi</span>
        </li>

        <li class="@(Model.Order.Status >= OrderStatus.Completed ? "done" : "")">
            <span>📦 Teslim Edildi</span>
        </li>

    </ul>

    @if (Model.Order.Status == OrderStatus.Rejected)
    {
        <div class="alert alert-danger">
            ❌ Siparişiniz iptal edildi.
        </div>
    }

</div>

<div class="mb-3">

    <strong>Risk Score:</strong> @ViewBag.RiskScore

    @{
        var score = (int)ViewBag.RiskScore;
    }

    @if (score >= 70)
    {
        <span class="badge bg-danger ms-2">HIGH RISK</span>
    }
    else if (score >= 40)
    {
        <span class="badge bg-warning text-dark ms-2">MEDIUM RISK</span>
    }
    else
    {
        <span class="badge bg-success ms-2">LOW RISK</span>
    }

</div>
<hr />

<h4 class="mt-4">Sipariş Durumu</h4>
<div class="mb-3">

    <a class="btn btn-outline-secondary btn-sm"
       href="@Url.Action("Details", new { id = Model.Order.Id })">
        Tümü
    </a>

    <a class="btn btn-outline-success btn-sm"
       href="@Url.Action("Details", new { id = Model.Order.Id, filter = TimelineEventType.PaymentReceived })">
        Payment
    </a>

    <a class="btn btn-outline-warning btn-sm"
       href="@Url.Action("Details", new { id = Model.Order.Id, filter = TimelineEventType.RefundRequested })">
        Refund
    </a>

    <a class="btn btn-outline-danger btn-sm"
       href="@Url.Action("Details", new { id = Model.Order.Id, filter = TimelineEventType.FraudDetected })">
        Fraud
    </a>

</div>

@if (ViewBag.RiskScore >= 70)
{
    <div class="alert alert-danger">
        🚨 Bu sipariş yüksek fraud riski içeriyor.
    </div>
}





    <div class="mb-3">

        <a asp-action="Details"
       asp-route-id="@Model.Order.Id"
           class="btn btn-sm btn-outline-secondary">
            All
        </a>

        <a asp-action="Details"
       asp-route-id="@Model.Order.Id"
           asp-route-filter="PaymentReceived"
           class="btn btn-sm btn-outline-success">
            Payments
        </a>

        <a asp-action="Details"
       asp-route-id="@Model.Order.Id"
           asp-route-filter="Refund"
           class="btn btn-sm btn-outline-warning">
            Refunds
        </a>

        <a asp-action="Details"
       asp-route-id="@Model.Order.Id"
           asp-route-filter="Fraud"
           class="btn btn-sm btn-outline-danger">
            Fraud
        </a>

    </div>

<h5 class="mt-4">Sipariş Durumu</h5>

<div class="timeline">

    @foreach (var item in ViewBag.Timeline)
    {
        <div class="timeline-item">

            <div class="timeline-icon @item.IconCss">
                <i class="@item.Icon"></i>
            </div>

            <div class="timeline-content">

                <strong>@item.Title</strong>

                <div class="text-muted small">
                    @item.Date.ToString("dd.MM.yyyy HH:mm")
                </div>

                <div>
                    @item.Description
                </div>

            </div>

        </div>
    }

</div>
@if (Model.Order.Status == OrderStatus.PaymentFailed)
{
    <div class="alert alert-danger mt-3">
        <strong>Ödeme başarısız.</strong>
        Lütfen tekrar deneyin.
    </div>

    <a asp-action="RetryPayment"
       asp-controller="Payment"
       asp-route-orderId="@Model.Order.Id"
       class="btn btn-warning">
        🔁 Tekrar Öde
    </a>
}

<p><strong>Sipariş No:</strong> @Model.Order.Id</p>
<p><strong>Tarih:</strong> @Model.Order.OrderDate</p>
<p><strong>Durum:</strong> @Model.Order.Status</p>
<p><strong>Toplam:</strong> @Model.Order.TotalPrice TL</p>


<h4>Ürünler</h4>
<ul>
    @foreach (var item in Model.Order.OrderItems)
    {
        <li>
            @item.Product.Name - @item.Quantity x @item.UnitPrice TL
        </li>
    }
</ul>
<div class="mt-4 text-center">
    <a href="/" class="btn btn-primary">
        🏠 Anasayfa’ya Dön
    </a>
</div>

<!-- PAYMENT SUCCESS MODAL -->
<div class="modal fade" id="paymentSuccessModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-center p-4">
            <div class="mb-3">
                <i class="bi bi-check-circle-fill text-success fs-1"></i>
            </div>

            <h4>Ödemeniz Başarıyla Alındı</h4>

            <p class="text-muted">
                Sipariş Numaranız: <strong>#@Model.Order.Id</strong>
            </p>

            <div class="d-flex justify-content-center gap-2 mt-3">
                <a href="/" class="btn btn-outline-secondary">Anasayfa</a>
                <button class="btn btn-success" data-bs-dismiss="modal">
                    Sipariş Detayı
                </button>
            </div>
        </div>
    </div>
</div>

@if (TempData["ShowPaymentSuccess"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var modalEl = document.getElementById('paymentSuccessModal');
            if (modalEl) {
                var modal = new bootstrap.Modal(modalEl);
                modal.show();
            }
        });
    </script>
}

@if (Model.Order.Status == OrderStatus.Paid && TempData["ShowPaymentSuccess"] == null)
{
    <script>
        setTimeout(function () {
            window.location.href = "/";
        }, 5000);
    </script>
    <div class="text-muted small mt-2">
        5 saniye içinde otomatik olarak Anasayfa’ya yönlendirileceksiniz.
    </div>
}


