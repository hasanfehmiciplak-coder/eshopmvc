@using EShopMVC.Modules.Orders
@using EShopMVC.Modules.Orders.Domain.Entities
@using EShopMVC.Modules.Orders.Domain
@using EShopMVC.Modules.Orders.Domain.Enums
@model List<Order>

<h3 class="mb-4">Siparişlerim</h3>

<div class="row">

    @foreach (var order in Model)
    {
        <div class="col-md-4 mb-4">

            <div class="card shadow-sm">

                <div class="card-body">

                    <h5 class="card-title">
                        Sipariş #@order.Id
                    </h5>

                    <p class="text-muted mb-1">
                        @order.OrderDate.ToString("dd.MM.yyyy")
                    </p>

                    <h6>
                        @order.TotalPrice ₺
                    </h6>

                    <span class="badge bg-@(
                          order.Status == OrderStatus.Delivered ? "success" :
                          order.Status == OrderStatus.Shipped ? "info" :
                          order.Status == OrderStatus.Cancelled ? "danger" :
                          "secondary")">

                    @order.Status

                    </span>

                    <div class="mt-3">

                        <a asp-controller="Orders"
                           asp-action="Details"
                           asp-route-id="@order.Id"
                           class="btn btn-sm btn-primary">

                            Sipariş Detayı

                        </a>

                    </div>

                </div>

            </div>

        </div>
    }

</div>