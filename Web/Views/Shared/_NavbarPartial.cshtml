                @if (User.Identity.IsAuthenticated)
                {
                    <li class="nav-item">
                        <a class="nav-link"
                           asp-controller="Orders"
                           asp-action="MyOrders">
                            📦 Siparişlerim
                        </a>
                    </li>
                }

                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item">
                        <a class="nav-link text-warning fw-semibold"
                           asp-area="Admin"
                           asp-controller="Dashboard"
                           asp-action="Index">
                            Admin Panel
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Admin"
                           asp-controller="Audit"
                           asp-action="Index">
                            🔍 Audit Log
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Admin"
                           asp-controller="PaymentLog"
                           asp-action="Index">
                            💳 Ödeme Logları
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Admin"
                           asp-controller="Security"
                           asp-action="Index">
                            🔐 Güvenlik
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Admin"
                           asp-controller="RefundFraud"
                           asp-action="Index">
                            🚨 Refund Fraud
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link"
                           asp-area="Admin"
                           asp-controller="Fraud"
                           asp-action="Index">
                            🚨 Fraud Flags
                        </a>
                    </li>

                    <a class="nav-link" asp-area="Admin"
                       asp-controller="Dashboard"
                       asp-action="Index">
