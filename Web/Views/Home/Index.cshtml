@using EShopMVC.Web.ViewModels
@model ProductListVM

<div class="container-fluid">
    <div class="row">
        <!-- Sol Sidebar -->
        <div class="col-md-3 bg-light p-3">
            <h5>Arama</h5>
            <form asp-action="Index" method="get">
                <input type="text" name="search" value="@Model.SearchString" class="form-control mb-2" placeholder="Ürün ara..." />
                <button type="submit" class="btn btn-primary btn-block">Ara</button>
            </form>

            <hr />

            <h5>Kategoriler</h5>
            <ul class="list-group">
                <li class="list-group-item">
                    <a asp-action="Index" asp-route-category="Elektronik">Elektronik</a>
                </li>
                <li class="list-group-item">
                    <a asp-action="Index" asp-route-category="Giyim">Giyim</a>
                </li>
                <li class="list-group-item">
                    <a asp-action="Index" asp-route-category="Kitap">Kitap</a>
                </li>
            </ul>
        </div>

        @if (ViewBag.CategoryName != null)
        {
            <h2>@ViewBag.CategoryName</h2>
        }
        else
        {
            <h2>Tüm Ürünler</h2>
        }


        <!-- Sağ Ürün Listesi -->
        <div class="col-md-9 p-3">
            <h4>Ürünler (@Model.TotalCount)</h4>

            @if (Model.Products != null && Model.Products.Any())
            {
                <div class="row">
                    @foreach (var product in Model.Products)
                    {
                        <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                            <div class="card product-card h-100 shadow-sm">
                                <img src="@(string.IsNullOrEmpty(product.ImageUrl) ? "/images/no-image.png" : product.ImageUrl)"
                                     class="card-img-top"
                                     alt="@product.Name"
                                     style="height:200px;object-fit:cover;" />
                                <div class="card-body d-flex flex-column">
                                    <h5 class="card-title">@product.Name</h5>
                                    <h5 class="text-primary mt-auto">@product.UnitPrice ₺</h5>                                    @if (product.Stock > 0)
                                    {
                                        <span class="badge bg-success">Stokta Var</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Stokta Yok</span>
                                    }

                                    @if (product.Stock > 0)
                                    {
                                        <button class="btn btn-primary btn-sm add-to-cart mt-2"
                                                data-id="@product.Id">
                                            Sepete Ekle
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-secondary" disabled>
                                            Stokta Yok
                                        </button>
                                    }

                                    <a asp-controller="Product"
                                       asp-action="Detail"
                                       asp-route-id="@product.Id"
                                       class="btn btn-outline-secondary btn-sm mt-2">
                                        Detay
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info">Kriterlere uygun ürün bulunamadı.</div>
            }
        </div>
    </div>
</div>