@using EShopMVC.Modules.Orders.Domain.Entities
@model List<CartItem>

  

<h2>Shopping Cart</h2>

<table class="table">

    <tr>
        <th>Product</th>
        <th>Size</th>
        <th>Color</th>
        <th>Price</th>
        <th>Qty</th>
        <th>Total</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.ProductName</td>
            <td>@item.Size</td>
            <td>@item.Color</td>
            <td>@item.UnitPrice</td>
            <td>@item.Quantity</td>
            <td>@(item.UnitPrice* item.Quantity)</td>
        </tr>
    }

</table>
