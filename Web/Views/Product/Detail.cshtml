@model EShopMVC.Models.Product

<h2>@Model.Name</h2>

<img src="@Model.ImageUrl" width="300" />

<p>@Model.Description</p>

<h4>@Model.UnitPrice ₺</h4>

<hr />

<h5>Select Size</h5>

@foreach (var size in Model.Variants.Select(v => v.Size).Distinct())
{
    <label>
        <input type="radio" name="size" value="@size" />
        @size
    </label>
}

<hr />

<h5>Select Color</h5>

@foreach (var color in Model.Variants.Select(v => v.Color).Distinct())
{
    <label>
        <input type="radio" name="color" value="@color" />
        @color
    </label>
}

<hr />

<button class="btn btn-primary">
    Add To Cart
</button>