@using EShopMVC.Models
@model Product

<div class="modal-header">
    <h5 class="modal-title">@Model.Name</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<div class="modal-body">
    <div class="row">
        <div class="col-md-6">
            <img src="@Model.ImageUrl" class="img-fluid rounded" />
        </div>
        <div class="col-md-6">
            <p class="text-muted">@Model.Category.Name</p>
            <h4 class="text-success">@Model.UnitPrice ₺</h4>

            <p>@Model.Description</p>

            @if (Model.Stock > 0)
            {
                <span class="badge bg-success">Stokta Var</span>
            }
            else
            {
                <span class="badge bg-danger">Stokta Yok</span>
            }
        </div>
    </div>
</div>

<div class="modal-footer">
    @if (Model.Stock > 0)
    {
        <button class="btn btn-primary"
                onclick="addToCart(@Model.Id)">
            Sepete Ekle
        </button>
    }
    else
    {
        <button class="btn btn-secondary" disabled>
            Stokta Yok
        </button>
    }
</div>
