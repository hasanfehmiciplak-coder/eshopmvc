@using EShopMVC.Models
@model Product

<div class="container mt-4">
    <h2>@Model.Name</h2>
    <div class="row">
        <div class="col-md-6">
            <img src="@Model.ImageUrl" class="img-fluid" alt="@Model.Name" />
        </div>
        <div class="col-md-6">
            <h4>Fiyat: @Model.UnitPrice ₺</h4>
            <p>@Model.Description</p>
            <button type="button"
                    class="btn btn-success add-to-cart-with-qty"
                    data-id="@Model.Id">
                Sepete Ekle
            </button>
            <a asp-action="Index" class="btn btn-secondary">Geri</a>
        </div>
    </div>
</div>